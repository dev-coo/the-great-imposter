# Vertex AI (production / Vercel)
# Paste the entire service-account JSON content as a single line.
GCP_CREDENTIALS_JSON=

# Vertex AI (local dev alternative)
# Path to the service-account JSON file. Use this OR GCP_CREDENTIALS_JSON.
# GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json

# GCP project & region for Vertex AI
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
